 requirements.txt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/requirements.txt b/requirements.txt
index 6a579cb..e1a7cc2 100644
--- a/requirements.txt
+++ b/requirements.txt
@@ -11,4 +11,4 @@ docxtpl==0.16.8
 segno==1.6.1
 Flask-Migrate==4.0.7
 alembic==1.13.2
-psycopg2-binary==2.9.9
+psycopg2-binary==2.9.10
