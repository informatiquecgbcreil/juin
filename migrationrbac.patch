-    # --- doublons certains ---
-    by_name = defaultdict(list)
-    by_email = defaultdict(list)
-    by_phone = defaultdict(list)
-
-    for p in items:
-        key_name = f"{_norm(p.nom)}|{_norm(p.prenom)}"
-        if _norm(p.nom) and _norm(p.prenom):
