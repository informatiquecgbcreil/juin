-    groups = []
-    def push_groups(source: str, dct):
-        for k, arr in dct.items():
-            if len(arr) >= 2:
-                groups.append({
-                    "type": source,
-                    "key": k,
-                    "items": sorted(arr, key=lambda x: (x.nom or "", x.prenom or "", x.id))
