# Identité de l'application
APP_NAME=App Gestion
ORGANIZATION_NAME=Votre structure

# Sécurité
# OBLIGATOIRE en production: clé aléatoire longue
SECRET_KEY=change-me-in-production

# Cookie de session transmis uniquement en HTTPS.
# Auto-activé si ERP_PUBLIC_BASE_URL commence par https://
# Forcer à 1 derrière un reverse-proxy TLS, laisser 0 en LAN HTTP pur.
# SESSION_COOKIE_SECURE=1

# Affiche le lien de réinitialisation de mot de passe dans la page
# (dev local sans SMTP uniquement — JAMAIS en production)
PASSWORD_RESET_ALLOW_DEBUG_LINK=0

# Environnement applicatif
# Valeurs possibles: development | production
ERP_ENV=development

# Réseau / serveur
ERP_HOST=127.0.0.1
ERP_PORT=8000
ERP_THREADS=12
ERP_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Base de données (priorité à SQLALCHEMY_DATABASE_URI, puis DATABASE_URL)
# Exemple PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/app_gestion

# Optionnel: répertoire de données applicatives (exports, fichiers)
# APP_DATA_DIR=/var/lib/app-gestion

# Optionnel: dossier des pièces jointes / logos
# APP_UPLOAD_DIR=/var/lib/app-gestion/uploads

# SMTP optionnel
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=1
MAIL_SENDER=

# Migration DB (Alebmic/Flask-Migrate)
DB_AUTO_UPGRADE_ON_START=1
# Compat legacy: activer uniquement pour anciennes bases non migrées
DB_ENABLE_LEGACY_SCHEMA_PATCH=0

# Publication du programme public (FTPS vers un hébergement, ex: cPanel) — optionnel
# Laisser vide pour désactiver la publication automatique.
PROGRAMME_FTP_HOST=
PROGRAMME_FTP_PORT=21
PROGRAMME_FTP_USER=
PROGRAMME_FTP_PASSWORD=
PROGRAMME_FTP_DIR=public_html
PROGRAMME_FTP_FILENAME=programme.html
PROGRAMME_PUBLIC_URL=

# Portail des apprenants (intégration REST externe) — optionnel
# Laisser vide pour désactiver l'intégration. Le jeton est fourni par le portail.
PORTAIL_BASE_URL=
PORTAIL_TOKEN=
